{
  "name": "prism-finance",
  "version": "0.2.0",
  "description": "AI-powered personal finance with liquid glass UI",
  "author": "Prism Finance",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:desktop": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run build:web",
    "build:web": "next build",
    "build:web:packaged": "next build && node scripts/patch-static-paths.mjs",
    "build:desktop": "npm run build:web:packaged && electron-builder --win --publish never",
    "build:desktop:publish": "npm run build:web:packaged && electron-builder --win --publish always",
    "build:android": "npm run build:web:packaged && npx cap sync android && node scripts/patch-android.mjs",
    "cap:open:android": "npx cap open android",
    "lint": "next lint"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.2.0",
    "@capacitor/network": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.prism.finance",
    "productName": "Prism Finance",
    "directories": {
      "output": "dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/ws/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "asarUnpack": [
      "node_modules/ws/**/*"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "LuminaGlpyhProd",
        "repo": "prism-finance"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "Prism-Finance-Setup-${version}.exe"
    }
  }
}
