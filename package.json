{
  "name": "prism-finance",
  "version": "0.1.0",
  "description": "AI-powered personal finance with liquid glass UI",
  "author": "Prism Finance",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:desktop": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run build:web",
    "build:web": "cross-env BUILD_STATIC=1 next build",
    "build:desktop": "npm run build:web && electron-builder --win",
    "build:android": "npm run build:web && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "lint": "next lint"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.2.0",
    "@capacitor/status-bar": "^6.0.2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.prism.finance",
    "productName": "Prism Finance",
    "directories": {
      "output": "dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Prism-Finance-${version}.exe"
    }
  }
}
